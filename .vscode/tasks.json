{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "make debug",
      "type": "shell",
      "command": "make debug",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "paste snippet into current file",
      "type": "shell",
      "command": "python3",
      "args": [
        "${workspaceFolder}/.vscode/paste_snippet.py",
        "${file}",
        "${workspaceFolder}/.vscode/c.code-snippets"
      ],
      "problemMatcher": []
    }
  ]
}
